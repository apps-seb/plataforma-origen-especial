        public function payment_scripts() {
            if ( ! is_cart() && ! is_checkout() && ! isset( $_GET['pay_for_order'] ) ) {
                return;
            }
            if ( ! $this->is_available() ) {
                return;
            }

            $user_id = get_current_user_id();
            $puntos = get_user_meta( $user_id, 'origen_puntos', true );
            $puntos = $puntos ? floatval($puntos) : 0;

            // Mostrar puntos disponibles en la pasarela, y actualizar checkout al elegir
            wp_register_script( 'woocommerce_origen_puntos', '', array('jquery'), false, true );
            wp_enqueue_script( 'woocommerce_origen_puntos' );

            $script = "
            jQuery(function($) {
                $(document.body).on('updated_checkout', function() {
                    const desc = $('.payment_method_origen_puntos .payment_box p');
