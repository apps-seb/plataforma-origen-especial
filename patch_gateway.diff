                        desc.append('<br><br><span class=\"puntos-badge\" style=\"background:#10b981; color:white; padding:5px 10px; border-radius:5px; font-weight:bold;\">Tus Puntos Disponibles: ' + " . number_format($puntos, 0, ',', '.') . " Pts</span>');
                    }
                });

                $(document).on('change', 'input[name=\"payment_method\"]', function() {
                    if($(this).val() === 'origen_puntos') {
                        $('body').trigger('update_checkout');
                    }
                });
            });
            ";
            wp_add_inline_script( 'woocommerce_origen_puntos', $script );
        }

